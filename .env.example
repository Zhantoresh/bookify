API_PORT=8080
READ_TIMEOUT=15s
WRITE_TIMEOUT=15s
IDLE_TIMEOUT=60s
SHUTDOWN_GRACE=30s

LOG_LEVEL=info
APP_NAME=BookingSystem
APP_ENV=development
