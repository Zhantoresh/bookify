                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"email\":\"{{provider_email}}\",\"password\":\"{{provider_password}}\",\"full_name\":\"{{provider_name}}\",\"role\":\"provider\",\"phone\":\"+70000000020\"}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register",
